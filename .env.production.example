# ─────────────────────────────────────────────────────────────────────────────
# AIRONA — Production Environment Template
# Copy to .env on the production server, fill in all values, never commit.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="Airona Globus"
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://airona.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=14

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=error

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=airona
DB_USERNAME=airona
DB_PASSWORD=                    # strong random password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                 # strong random password

# ── Sessions & Cache ─────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=airona.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis

QUEUE_CONNECTION=redis

# ── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=s3

# Cloudflare R2 (S3-compatible)
AWS_ACCESS_KEY_ID=              # R2 access key ID
AWS_SECRET_ACCESS_KEY=          # R2 secret access key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=airona-vouchers
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Mail (Mailgun / Postmark) ─────────────────────────────────────────────────
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS=hola@airona.com
MAIL_FROM_NAME="Airona Globus"

MAILGUN_DOMAIN=mg.airona.com
MAILGUN_SECRET=                 # Mailgun API key
MAILGUN_ENDPOINT=api.eu.mailgun.net

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_live_              # Publishable key
STRIPE_SECRET=sk_live_           # Secret key — keep secret!
STRIPE_WEBHOOK_SECRET=whsec_    # From Stripe Dashboard webhook endpoint

# ── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=airona.com,www.airona.com

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=             # https://xxx@oXXX.ingest.sentry.io/YYY
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# ── Frontend (injected at build time via CI) ──────────────────────────────────
VITE_API_URL=/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_
VITE_SENTRY_DSN=                # Frontend Sentry DSN (can differ from backend)
VITE_SENTRY_ENVIRONMENT=production

# ── GitHub Container Registry (used by docker-compose.prod.yml) ───────────────
GITHUB_REPOSITORY=your-org/airona
APP_VERSION=latest              # Set by CI to the release tag, e.g. v1.2.0
