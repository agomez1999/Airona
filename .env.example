# ─────────────────────────────────────────────────────────────────────────────
# AIRONA — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker Port Overrides ─────────────────────────────────────────────────────
APP_PORT=80
DB_PORT_FORWARD=5432
REDIS_PORT_FORWARD=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND (Laravel)
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Airona Globus"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ── Frontend URL (for CORS, email links, Stripe redirect URLs) ────────────────
FRONTEND_URL=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=airona
DB_USERNAME=airona
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Queue & Cache ─────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false  # set to true in production (HTTPS)
SESSION_SAME_SITE=lax

# ── Email ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hola@airona.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys (use test keys for local)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_CURRENCY=eur

# ── File Storage ──────────────────────────────────────────────────────────────
# local: files stored in backend/storage/app/
# s3: files stored in AWS S3 or Cloudflare R2
FILESYSTEM_DISK=local

# S3 / Cloudflare R2 (required if FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=airona-vouchers
AWS_URL=
AWS_ENDPOINT=  # Set for Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com

# ── Voucher Configuration ─────────────────────────────────────────────────────
VOUCHER_VALIDITY_DAYS=365
VOUCHER_DOWNLOAD_URL_TTL_HOURS=72
VOUCHER_PDF_STORAGE_PATH=vouchers

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Broadcasting (optional for future real-time features) ─────────────────────
BROADCAST_DRIVER=log

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Vite / React)
# ─────────────────────────────────────────────────────────────────────────────

VITE_APP_URL="${APP_URL}"
VITE_API_URL="${APP_URL}/api/v1"
VITE_STRIPE_PUBLISHABLE_KEY="${STRIPE_PUBLISHABLE_KEY}"

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION ADDITIONS (not needed locally)
# ─────────────────────────────────────────────────────────────────────────────

# SESSION_SECURE_COOKIE=true
# APP_DEBUG=false
# APP_ENV=production
# LOG_LEVEL=error
# MAIL_MAILER=mailgun   # or postmark
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=<mailgun_user>
# MAIL_PASSWORD=<mailgun_password>
